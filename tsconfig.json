{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"target": "ES2018",
		"moduleResolution": "node",
		"allowJs": false,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strict": true,
		"lib": ["DOM", "ES2018", "ES2020"],
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts"]
}
